{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "clusterDomain": {"type": "string"},
    "mongodb": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "external": {
          "type": "object",
          "properties": {
            "uri": {"type": "string"},
            "existingSecret": {"type": "string"},
            "existingSecretKey": {"type": "string"}
          }
        }
      }
    },
    "valkey": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "external": {
          "type": "object",
          "properties": {
            "url": {"type": "string"},
            "existingSecret": {"type": "string"},
            "existingSecretKey": {"type": "string"}
          }
        }
      }
    },
    "llmAdapter": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "deploy": {"type": "boolean"},
        "backendURL": {"type": "string"},
        "ollamaURL": {"type": "string"},
        "promptPrivacyMode": {"enum": ["text_only", "markdown"]}
      }
    },
    "gateway": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "create": {"type": "boolean"},
        "name": {"type": "string"},
        "namespace": {"type": "string"},
        "className": {"type": "string"},
        "annotations": {"type": "object"},
        "labels": {"type": "object"},
        "listeners": {"type": "array"}
      }
    },
    "httpRoute": {
      "type": "object",
      "properties": {
        "annotations": {"type": "object"},
        "labels": {"type": "object"},
        "parentRefs": {"type": "array"},
        "hostnames": {"type": "array", "items": {"type": "string"}},
        "rules": {"type": "array"}
      }
    }
  }
}
