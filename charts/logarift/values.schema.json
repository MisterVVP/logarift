{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "clusterDomain": {"type": "string"},
    "mongodb": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "external": {
          "type": "object",
          "properties": {
            "uri": {"type": "string"},
            "existingSecret": {"type": "string"},
            "existingSecretKey": {"type": "string"}
          }
        }
      }
    },
    "valkey": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "external": {
          "type": "object",
          "properties": {
            "url": {"type": "string"},
            "existingSecret": {"type": "string"},
            "existingSecretKey": {"type": "string"}
          }
        }
      }
    },
    "llmAdapter": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "deploy": {"type": "boolean"},
        "backendURL": {"type": "string"},
        "ollamaURL": {"type": "string"},
        "model": {"type": "string"},
        "timeoutMS": {"type": "integer"},
        "minConfidence": {"type": "string"},
        "allowRemoteRuntime": {"type": "boolean"},
        "promptPrivacyMode": {"enum": ["text_only", "markdown"]}
      }
    },
    "ollama": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "replicaCount": {"type": "integer"},
        "image": {
          "type": "object",
          "properties": {
            "repository": {"type": "string"},
            "tag": {"type": "string"},
            "digest": {"type": "string"},
            "pullPolicy": {"type": "string"}
          }
        },
        "service": {
          "type": "object",
          "properties": {
            "type": {"type": "string"},
            "port": {"type": "integer"}
          }
        },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "size": {"type": "string"},
            "storageClassName": {"type": "string"},
            "accessModes": {"type": "array", "items": {"type": "string"}}
          }
        },
        "env": {"type": "object"},
        "extraEnv": {"type": "array"},
        "acceleration": {
          "type": "object",
          "properties": {
            "type": {"enum": ["none", "amd", "nvidia"]},
            "gpuCount": {"type": "integer", "minimum": 1},
            "runtimeClassName": {"type": "string"},
            "nodeSelector": {"type": "object"},
            "tolerations": {"type": "array"},
            "extraEnv": {"type": "array"},
            "amd": {
              "type": "object",
              "properties": {
                "imageTag": {"type": "string"},
                "hostDevices": {
                  "type": "object",
                  "properties": {
                    "enabled": {"type": "boolean"},
                    "privileged": {"type": "boolean"},
                    "kfdPath": {"type": "string"},
                    "driPath": {"type": "string"}
                  }
                },
                "hsaOverrideGfxVersion": {"type": "string"},
                "resourceName": {"type": "string"}
              }
            },
            "nvidia": {
              "type": "object",
              "properties": {
                "imageTag": {"type": "string"},
                "resourceName": {"type": "string"},
                "visibleDevices": {"type": "string"},
                "driverCapabilities": {"type": "string"}
              }
            }
          }
        },
        "resources": {"type": "object"},
        "podAnnotations": {"type": "object"},
        "podLabels": {"type": "object"},
        "nodeSelector": {"type": "object"},
        "tolerations": {"type": "array"},
        "affinity": {"type": "object"},
        "topologySpreadConstraints": {"type": "array"},
        "livenessProbe": {"type": "object"},
        "readinessProbe": {"type": "object"},
        "modelInit": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "baseModel": {"type": "string"},
            "model": {"type": "string"},
            "modelfile": {"type": "string"}
          }
        }
      }
    },
    "gateway": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "create": {"type": "boolean"},
        "name": {"type": "string"},
        "namespace": {"type": "string"},
        "className": {"type": "string"},
        "annotations": {"type": "object"},
        "labels": {"type": "object"},
        "listeners": {"type": "array"}
      }
    },
    "httpRoute": {
      "type": "object",
      "properties": {
        "annotations": {"type": "object"},
        "labels": {"type": "object"},
        "parentRefs": {"type": "array"},
        "hostnames": {"type": "array", "items": {"type": "string"}},
        "rules": {"type": "array"}
      }
    }
  }
}
